generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("SUPER_ADMIN")
  createdAt DateTime @default(now())
}

model Course {
  id                String        @id @default(cuid())
  title             String
  description       String?
  status            String        @default("DRAFT")
  deadline          DateTime?
  maxSeats          Int?
  fee               Float?        @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  appNumberPrefix   String        @default("APP-")
  currentAppCounter Int           @default(1000)
  appNumberDigits   Int           @default(4)
  requiredDocuments Json?
  subCourses        Json?
  applications      Application[]
}

model Application {
  id            String    @id @default(cuid())
  applicationNo String    @unique
  status        String    @default("PENDING")
  dob           DateTime
  data          Json
  courseId      String
  isEditable    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  course        Course    @relation(fields: [courseId], references: [id])
}

model ApplicationStatus {
  id          String   @id @default(cuid())
  label       String   @unique
  value       String   @unique
  color       String   @default("indigo")
  createdAt   DateTime @default(now())
  description String?
}

model SystemSettings {
  id                    Int      @id @default(1)
  globalEditSubmissions Boolean  @default(false)
  fileUploadSizeLimitMB Int      @default(5)
  updatedAt             DateTime @updatedAt
}
